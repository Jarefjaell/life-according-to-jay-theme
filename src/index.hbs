{{!< default}}

{{!-- Lead piece: most recent post --}}
{{#get "posts" limit="1" include="tags"}}
    {{#foreach posts}}
    <section class="lead-piece">
        <p class="label-rule">Most recent</p>
        <div class="lead-meta">
            <span class="lead-meta-date">{{date format="D MMMM YYYY"}}</span>
            {{#primary_tag}}<span class="lead-meta-category"><a href="{{url}}">{{name}}</a></span>{{/primary_tag}}
            {{#has tag="#deep"}}<span class="lead-meta-complexity">deep</span>{{/has}}
            {{#has tag="#layered"}}<span class="lead-meta-complexity">layered</span>{{/has}}
            {{#has tag="#light"}}<span class="lead-meta-complexity">light</span>{{/has}}
        </div>
        <h1 class="lead-title"><a href="{{url}}">{{title}}</a></h1>
        <p class="lead-excerpt">{{excerpt words="50"}}</p>
        <a href="{{url}}" class="lead-readon">Read on →</a>
    </section>
    {{/foreach}}
{{/get}}

{{!-- Selected writing: featured posts (lead piece may appear here if also featured;
     accepted as a minor duplication risk pending a future filter-by-id refinement) --}}
{{#get "posts" filter="featured:true" limit="6" include="tags"}}
    {{#if posts.length}}
    <section class="section">
        <h2 class="label-rule">Selected writing</h2>
        <div class="article-list">
            {{#foreach posts}}
                {{> article-card}}
            {{/foreach}}
        </div>
    </section>
    {{/if}}
{{/get}}

{{!-- Closing row --}}
<section class="closing-row">
    <a href="{{@site.url}}/writing/" class="closing-link">Read all writing →</a>
    <a href="{{@site.url}}/the-why/" class="closing-link">The Why? →</a>
</section>

