{{!< default}}

{{#post}}
<article class="article-page">

    <header class="article-page-header">
        <div class="article-meta-top">
            {{#has tag="#light"}}<span>light</span><span class="sep">&middot;</span>{{/has}}{{#has tag="#layered"}}<span>layered</span><span class="sep">&middot;</span>{{/has}}{{#has tag="#deep"}}<span>deep</span><span class="sep">&middot;</span>{{/has}}<span>{{date format="D MMMM YYYY"}}</span>{{#primary_tag}}<span class="sep">&middot;</span><a href="{{url}}">{{name}}</a>{{/primary_tag}}
        </div>
        <h1 class="article-page-title">{{title}}{{#has tag="#anchor"}}<span class="marker anchor">anchor</span>{{/has}}</h1>
        {{#if custom_excerpt}}
            <p class="article-byline">{{custom_excerpt}}</p>
        {{/if}}
        {{#has tag="#cookie-series"}}
        <p class="article-cross-ref">Also at another depth: {{#has tag="#deep"}}<a href="/did-you-really-believe-the-nullification-of-cookies-came-without-a-price/">layered</a> &middot; <a href="/the-bit-you-were-not-told-about/">light</a>{{/has}}{{#has tag="#layered"}}<a href="/the-ripple-you-cannot-see/">deep</a> &middot; <a href="/the-bit-you-were-not-told-about/">light</a>{{/has}}{{#has tag="#light"}}<a href="/the-ripple-you-cannot-see/">deep</a> &middot; <a href="/did-you-really-believe-the-nullification-of-cookies-came-without-a-price/">layered</a>{{/has}}</p>
        {{/has}}
    </header>

    <div class="article-body">
        {{content}}
    </div>

    <div class="coda">

        <section class="not-comments">
            <h2>Not a comment section</h2>
            <p>I am less interested in traditional article comments than in thoughtful exchange. If this piece prompted a response, the conversation continues on LinkedIn.</p>
            <a class="continue-link" id="linkedin-link" href="https://linkedin.com/in/im-jakob" target="_blank" rel="noopener">Continue the exchange &rarr;</a>
        </section>

        <section class="actions" aria-label="Take it with you">
            <div class="action-row">
                <span class="row-label">Save</span>
                <div class="row-actions">
                    <button class="action" type="button" data-action="pdf" aria-label="Save as PDF">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                        <span>PDF</span>
                    </button>
                </div>
            </div>

            <div class="action-row">
                <span class="row-label">Send</span>
                <div class="row-actions">
                    <button class="action" type="button" data-action="copy-link" data-url="{{url absolute="true"}}" aria-label="Copy link">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                        <span>Copy link</span>
                    </button>
                    <a class="action" href="https://www.linkedin.com/sharing/share-offsite/?url={{url absolute="true" encode="true"}}" target="_blank" rel="noopener" aria-label="Share on LinkedIn">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="2"/><line x1="8" y1="11" x2="8" y2="17"/><circle cx="8" cy="8" r="0.8" fill="currentColor" stroke="none"/><path d="M12 17v-4a2 2 0 0 1 4 0v4M12 11v6"/></svg>
                        <span>LinkedIn</span>
                    </a>
                    <a class="action" href="mailto:?subject={{encode title}}&amp;body={{encode title}}%0A%0A{{url absolute="true"}}" aria-label="Share via Email">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7L12 14 2 7"/></svg>
                        <span>Email</span>
                    </a>
                    <a class="action" href="https://teams.microsoft.com/share?href={{url absolute="true" encode="true"}}&amp;msgText={{encode title}}" target="_blank" rel="noopener" aria-label="Share on Teams">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                        <span>Teams</span>
                    </a>
                </div>
            </div>
        </section>

        {{#has tag="#measurement-part-1,#measurement-part-2,#measurement-part-3,#measurement-part-4"}}
            {{#get "posts" filter="tag:[hash-measurement-part-1,hash-measurement-part-2,hash-measurement-part-3,hash-measurement-part-4]" order="published_at asc" limit="all" include="tags" as |seriesPosts|}}
            <section class="series-coda">
                <h2 class="series-coda-title">The measurement series</h2>
                <ol class="series-coda-list">
                    {{#foreach seriesPosts}}
                        {{#match id "=" ../id}}
                        <li class="series-coda-item current">
                            <span class="series-coda-part">{{#has tag="#measurement-part-1"}}part 1 of 4{{/has}}{{#has tag="#measurement-part-2"}}part 2 of 4{{/has}}{{#has tag="#measurement-part-3"}}part 3 of 4{{/has}}{{#has tag="#measurement-part-4"}}part 4 of 4{{/has}}</span>
                            <span class="series-coda-name">{{title}}</span>
                            <span class="series-coda-here">you are reading this</span>
                        </li>
                        {{else}}
                        <li class="series-coda-item">
                            <a href="{{url}}">
                                <span class="series-coda-part">{{#has tag="#measurement-part-1"}}part 1 of 4{{/has}}{{#has tag="#measurement-part-2"}}part 2 of 4{{/has}}{{#has tag="#measurement-part-3"}}part 3 of 4{{/has}}{{#has tag="#measurement-part-4"}}part 4 of 4{{/has}}</span>
                                <span class="series-coda-name">{{title}}</span>
                            </a>
                        </li>
                        {{/match}}
                    {{/foreach}}
                </ol>
            </section>
            {{/get}}
        {{else}}
            <p class="closeout">If you made it down here, your mind deserves a break.</p>
        {{/has}}

    </div>

</article>

<div class="toast" id="toast" role="status" aria-live="polite"></div>
{{/post}}
