{{!< default}}

{{#post}}
<article class="article-page">
    <header class="article-page-header">
        <div class="article-meta">
            {{#primary_tag}}<span class="article-category">{{name}}</span> &bull; {{/primary_tag}}{{date format="D MMMM YYYY"}}
        </div>
        {{> complexity}}
        <h1 class="article-page-title">{{title}}</h1>
        {{#if custom_excerpt}}
            <p class="article-standfirst">{{custom_excerpt}}</p>
        {{/if}}
    </header>

    <div class="article-body">
        {{content}}
    </div>
</article>

{{!-- Share --}}
<div class="share-block">
    <div class="share-label">Share this piece</div>
    <div class="share-actions">
        <button class="share-btn" id="share-copy" data-url="{{url absolute="true"}}" title="Copy link" aria-label="Copy link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            <span class="share-btn-label">Copy link</span>
        </button>
        <a class="share-btn" href="https://www.linkedin.com/sharing/share-offsite/?url={{url absolute="true" encode="true"}}" target="_blank" rel="noopener" title="Share on LinkedIn" aria-label="Share on LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            <span class="share-btn-label">LinkedIn</span>
        </a>
        <a class="share-btn" href="mailto:?subject={{encode title}}&body=I thought you might find this interesting: {{url absolute="true"}}" title="Share via Email" aria-label="Share via Email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <span class="share-btn-label">Email</span>
        </a>
        <a class="share-btn" href="https://teams.microsoft.com/share?href={{url absolute="true" encode="true"}}&msgText={{encode title}}" target="_blank" rel="noopener" title="Share on Teams" aria-label="Share on Teams">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.2 6.4h-1.6V4.8c0-.88.72-1.6 1.6-1.6s1.6.72 1.6 1.6-.72 1.6-1.6 1.6zm2.4 2.4h-4c-.44 0-.8.36-.8.8v4.8c0 1.32 1.08 2.4 2.4 2.4s2.4-1.08 2.4-2.4V9.6c0-.44-.36-.8-.8-.8zM14.4 4.8c0-1.76-1.44-3.2-3.2-3.2S8 3.04 8 4.8s1.44 3.2 3.2 3.2 3.2-1.44 3.2-3.2zM16 10H6.4c-.88 0-1.6.72-1.6 1.6v5.2c0 2.64 2.16 4.8 4.8 4.8h2c2.64 0 4.8-2.16 4.8-4.8v-5.2c0-.88-.72-1.6-1.6-1.6z"/></svg>
            <span class="share-btn-label">Teams</span>
        </a>
        <a class="share-btn share-btn-mobile" href="https://wa.me/?text={{encode title}}%20{{url absolute="true" encode="true"}}" target="_blank" rel="noopener" title="Share on WhatsApp" aria-label="Share on WhatsApp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span class="share-btn-label">WhatsApp</span>
        </a>
    </div>
</div>

{{!-- LinkedIn conversation --}}
<div class="linkedin-conversation" id="linkedin-conversation">
    <div class="linkedin-conversation-heading">Not a comment section</div>
    <p class="linkedin-conversation-text">I am less interested in traditional article comments than in thoughtful exchange. If this piece prompted a response, the conversation continues on LinkedIn.</p>
    <a class="linkedin-conversation-link" id="linkedin-link" href="https://linkedin.com/in/im-jakob" target="_blank" rel="noopener">Continue the exchange &rarr;</a>
</div>

{{!-- Author note --}}
{{#primary_author}}
<div class="author-note">
    <div class="author-note-label">About the author</div>
    {{#if bio}}
        <p>{{bio}}</p>
    {{else}}
        <p>{{name}} writes about systems, work, technology, and modern life. Life According to Jay is his home for writing that takes its time.</p>
    {{/if}}
</div>
{{/primary_author}}

{{!-- Related Writing --}}
{{#get "posts" filter="id:-{{id}}" limit="3"}}
    {{#if posts.length}}
    <div class="related-writing">
        <div class="section-header">Related Writing</div>
        <div class="article-list">
            {{#foreach posts}}
                {{> article-card}}
            {{/foreach}}
        </div>
    </div>
    {{/if}}
{{/get}}

{{/post}}
