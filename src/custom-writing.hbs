{{!< default}}

<section class="writing-archive">
    {{#get "posts" limit="all" include="tags"}}
    <header class="writing-header">
        <h1>Writing</h1>
        <p class="writing-subtitle">All published writing, across every topic.</p>
        <p class="writing-dateline">{{posts.length}} essays<span class="sep">&middot;</span>most recent first<span class="sep">&middot;</span>updated continuously since 2024</p>
        <p class="writing-explainer">Pieces are tagged light, layered, or deep, signalling cognitive weight rather than reading time.</p>
        <p class="writing-explainer">Where you see <span class="marker anchor">anchor</span>, the piece is the entry point of a series or a set of companion pieces at other depths.</p>
        <div class="filter-bar" id="filter-bar">
            <button class="filter-btn active" data-filter="all">All</button>
        </div>
    </header>

    <div class="article-list" id="writing-list">
        {{#foreach posts}}
            {{> article-card}}
        {{/foreach}}
    </div>
    {{/get}}
</section>
